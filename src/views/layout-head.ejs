<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Serrano30</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background-color: #f4f6f9; }
    .navbar { background-color: #2F5496 !important; }
    .stat-card { border-left: 4px solid; }
    .stat-pending { border-left-color: #ffc107; }
    .stat-analyzed { border-left-color: #198754; }
    .stat-error { border-left-color: #dc3545; }
    .stat-total { border-left-color: #2F5496; }
    .badge-pending { background-color: #ffc107; color: #000; }
    .badge-analyzed { background-color: #198754; }
    .badge-error { background-color: #dc3545; }
  </style>
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
  <nav class="navbar navbar-dark px-3">
    <span class="navbar-brand mb-0 h1">Serrano30</span>
    <form method="POST" action="/logout" class="d-inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-outline-light btn-sm">Cerrar sesión</button>
    </form>
  </nav>
  <% } %>
  <div class="container-fluid py-4 px-4">
