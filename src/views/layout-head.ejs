<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Serrano30</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background-color: #f4f6f9; }
    .navbar { background-color: #2F5496 !important; }
    .stat-card { border-left: 4px solid; }
    .stat-pending { border-left-color: #ffc107; }
    .stat-analyzed { border-left-color: #198754; }
    .stat-error { border-left-color: #dc3545; }
    .stat-total { border-left-color: #2F5496; }
    .badge-pending { background-color: #ffc107; color: #000; }
    .badge-analyzed { background-color: #198754; }
    .badge-error { background-color: #dc3545; }
  </style>
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
  <nav class="navbar navbar-dark px-3">
    <div class="d-flex align-items-center gap-3">
      <span class="navbar-brand mb-0 h1">Serrano30</span>
      <ul class="nav nav-pills">
        <li class="nav-item">
          <a class="nav-link <%= typeof activeTab !== 'undefined' && activeTab === 'descarga' ? 'active' : 'text-light' %>" href="/descarga">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download me-1" viewBox="0 0 16 16"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
            Descarga
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= typeof activeTab !== 'undefined' && activeTab === 'analisis' ? 'active' : 'text-light' %>" href="/analisis">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-bar-graph me-1" viewBox="0 0 16 16"><path d="M10 13.5a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-6a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5zm-2.5.5a.5.5 0 0 1-.5-.5v-4a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-.5.5zm-3 0a.5.5 0 0 1-.5-.5v-2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.5.5z"/><path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/></svg>
            Análisis
          </a>
        </li>
      </ul>
    </div>
    <form method="POST" action="/logout" class="d-inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-outline-light btn-sm">Cerrar sesión</button>
    </form>
  </nav>
  <% } %>
  <div class="container-fluid py-4 px-4">
