# --- Servidor Web ---
PORT=3000
NODE_ENV=development

# Admin (único usuario)
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contraseña

# Secreto para sesiones (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# --- API OpenAI (para análisis de notas) ---
OPENAI_API_KEY=sk-xxxx

# --- Script de descarga (Playwright) ---
CERT_PATH=./certificado.p12
CERT_PASSPHRASE=tu_contraseña_aqui
DOWNLOAD_DIR=./descargas
MAX_PAGES=0

# --- Análisis CLI (legacy) ---
NOTAS_DIR=./notas-simples
OUTPUT_EXCEL=./notas-simples/resultado.xlsx
